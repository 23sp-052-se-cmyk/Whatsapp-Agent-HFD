# ─── PostgreSQL ───────────────────────────────────────────────
# Admin/superuser connection — used by drizzle-kit and migrations only
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/appdb
# App role connection — subject to RLS (used by application services)
DATABASE_APP_URL=postgresql://app_user:app_password@localhost:5432/appdb

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MinIO (S3-compatible object storage) ─────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=whatsapp-bot

# ─── Mailhog (local SMTP / email capture) ─────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# ─── NestJS API ───────────────────────────────────────────────
API_PORT=5000
JWT_SECRET=change-me-in-production-use-32-random-chars
CORS_ORIGIN=http://localhost:3000

# ─── Channel worker ───────────────────────────────────────────
CHANNEL_QUEUE_NAME=outbound-messages
# Optional: override default session directory for Baileys auth state
# SESSION_DIR=/var/data/sessions

# ─── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
